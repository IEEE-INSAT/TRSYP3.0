# ============================================================================
# TRSYP 3.0 Backend - Environment Variables
# ============================================================================

# App
NODE_ENV=development
PORT=3001
API_PREFIX=api
FRONTEND_URL=http://localhost:3000
# Additional browser origins allowed to call the API (comma-separated).
CORS_ORIGINS=https://rtc.ieee.tn,https://trsyp.ieee.tn

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# SBERT Embeddings
SBERT_MODEL_NAME=all-MiniLM-L6-v2

# Auth email delivery is configured in the Supabase Dashboard, not on Render.
# See docs/supabase-gmail-smtp.md for the Gmail SMTP settings.
