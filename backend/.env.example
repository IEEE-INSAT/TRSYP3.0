# ============================================================================
# TRSYP 3.0 Backend - Environment Variables
# ============================================================================

# App
NODE_ENV=development
PORT=3001
API_PREFIX=api
FRONTEND_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# SBERT Embeddings
SBERT_MODEL_NAME=all-MiniLM-L6-v2

# Email delivery
# Render free services cannot connect to SMTP ports. Use Resend there, with a
# verified sending domain/address. Keep credentials out of version control.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="TRSYP 3.0 <trsyp@ieee.tn>"

# Optional SMTP alternative for local development or a paid Render service.
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=trsyp@ieee.tn
# SMTP_PASSWORD=your_google_app_password
