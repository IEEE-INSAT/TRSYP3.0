// Prisma schema for TRSYP 3.0
// Uses PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Each domain module owns its own models.
// Models are organized by module boundary.
// No cross-module entity references — use domain events for inter-module comms.
// ============================================================================

// --- Auth Module ---
model User {
  id    String @id @default(uuid())
  email     String   @unique
  password String?
  name      String
  lastName  String
  supabaseId String @unique
  provider String @default("email")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
enum Position {
  CHAIR
  VICE_CHAIR
  // add more as needed
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  lastName  String
  position  Position
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

