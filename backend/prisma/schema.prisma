// Prisma schema for TRSYP 3.0
// Uses PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Each domain module owns its own models.
// Models are organized by module boundary.
// No cross-module entity references — use domain events for inter-module comms.
// ============================================================================

// --- Auth Module ---
model User {
  id    String @id @default(uuid())
  email     String   @unique
  name      String
  lastName  String
  supabaseId String @unique
  provider String @default("email")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
enum Position {
  CHAIR
  VICE_CHAIR
  // add more as needed
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  lastName  String
  position  Position
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  supabaseId String @unique

  @@map("admins")
}

// --- Registration Module ---
// Define registration-related models here

// --- Payment Module ---
// Define payment-related models here

// --- Rooming Module ---
// Define rooming-related models here

// --- Visa Module ---
// Define visa-related models here

// --- Notification Module ---
// Define notification-related models here
enum NotificationType {
  ROOM_INVITATION
  PAYMENT_REVIEW_RESULT
  PAYMENT_PROOF_SUBMITTED
}
model Notification {
  id            String           @id @default(uuid())
  recipientId   String           // userId or adminId
  recipientType String           // "user" | "admin"
  type          NotificationType
  title         String
  message       String
  read          Boolean          @default(false)
  metadata      Json?            // flexible payload (paymentId, roomId, etc.)
  actionUrl     String?          // deep-link for click-to-navigate
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  @@index([recipientId, recipientType])
  @@index([recipientId, read])
  @@map("notifications")
}


// --- Email Module ---
// Define email-related models here
enum EmailStatus {
  PENDING
  SENT
  FAILED
}
model EmailLog {
  id          String      @id @default(uuid())
  recipient   String      // email address
  subject     String
  templateId  String      // e.g., "room-invitation", "payment-result"
  payload     Json        // template data
  status      EmailStatus @default(PENDING)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime    @default(now())
  @@index([recipient])
  @@index([status])
  @@map("email_logs")
}
