# ──────────────────────────────────────────────────────────────────────────
# TRSYP 3.0 Frontend — environment variables
# Copy this file to `.env.local` and fill in real values.
# Every var is read in lib/config.ts. All are optional: when a value is
# missing the app falls back to a local/offline "placeholder" mode so the UI
# stays usable until the backend is finished.
# ──────────────────────────────────────────────────────────────────────────

# Base URL of the NestJS backend (no trailing slash).
# The backend currently mounts controllers at the root (/auth, /admin, ...),
# so use the host without a path prefix.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase project — used for client-side authentication. The backend
# validates the Supabase JWT, so the frontend must sign in with Supabase and
# send the access token as a Bearer header. Leave blank to run in offline mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Feature flags — flip to "true" as the matching backend routes go live.
# Until then the related service methods use local placeholders.
# /registration/* (registration module is not wired into app.module yet)
NEXT_PUBLIC_FEATURE_REGISTRATION_API=false
# /registration/admin/* admin participant/challenger listing & moderation
NEXT_PUBLIC_FEATURE_ADMIN_API=false
